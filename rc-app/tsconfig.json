{
    "compilerOptions": {
        "target": "ES2017",
        "module": "commonjs",
        "lib": ["ES6"],
        "moduleResolution": "node",
        "declaration": true,
        "strict": true,
        "noImplicitAny": true,
        "removeComments": true,
        "noLib": false,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "strictNullChecks": false
    },
    "exclude": ["node_modules"]
}